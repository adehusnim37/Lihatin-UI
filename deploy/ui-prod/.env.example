# Keep local bind if using reverse proxy on same host
WEB_BIND_IP=127.0.0.1
NPM_REGISTRY=https://registry.npmjs.org

NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Must point to public backend URL used by browser
NEXT_PUBLIC_API_URL=http://api.lihat.in/v1
NEXT_PUBLIC_FRONTEND_URL=https://app.lihat.in
NEXT_PUBLIC_BRAND_URL=https://lihat.in
NEXT_PUBLIC_API_DOCS_URL=https://api.lihat.in/v1/docs/spec
NEXT_PUBLIC_POSTMAN_COLLECTION_URL=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Server-only JWT secret for local token verification in SSR auth guard
JWT_SECRET=
