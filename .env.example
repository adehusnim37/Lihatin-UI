# Frontend local env example (copy to .env.local for local dev)

# Next.js runtime mode (optional)
NODE_ENV=development

# Required public API base URL (must include /v1)
NEXT_PUBLIC_API_URL=http://localhost:8080/v1

# Public app URL used when generating short links
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# Brand/home URL for auth pages logo and links
NEXT_PUBLIC_BRAND_URL=http://localhost:3000

# Optional docs and integration links
NEXT_PUBLIC_API_DOCS_URL=http://localhost:8080/v1/docs/spec
NEXT_PUBLIC_POSTMAN_COLLECTION_URL=

# Optional captcha site key (support pages)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Optional server-only JWT secret used by SSR auth guard
JWT_SECRET=
